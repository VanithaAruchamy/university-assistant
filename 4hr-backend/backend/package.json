{
  "name": "university-assistant-backend",
  "version": "1.0.0",
  "description": "AI-Powered University Assistant - 4hr Hackathon",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit",
    "lint": "eslint . --ext .js",
    "build": "echo 'Build OK'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "xlsx": "^0.18.5",
    "pdf-parse": "^1.1.1",
    "openai": "^4.28.0",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["routes/**/*.js", "services/**/*.js", "middleware/**/*.js", "utils/**/*.js"],
    "coverageThreshold": { "global": { "lines": 60 } }
  }
}
